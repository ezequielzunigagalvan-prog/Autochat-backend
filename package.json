{
  "name": "autochat-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "npx prisma db push --accept-data-loss && npx prisma generate && node src/server.js",
    "db:push": "prisma db push",
    "start:local": "node src/server.js",
    "build": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:demo-user": "node prisma/ensure-demo-user.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "openai": "^6.34.0",
    "prisma": "^5.22.0",
    "twilio": "^6.0.0",
    "zod": "latest"
  },
  "devDependencies": {
    "nodemon": "latest"
  }
}
